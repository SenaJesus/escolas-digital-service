{
  "name": "escolas-digital-service",
  "version": "0.1.0",
  "private": true,
  "description": "API REST do escolas.digital",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "seed:admin": "tsx src/scripts/seedAdmin.ts",
    "ingest": "tsx src/ingestion/cli.ts",
    "ingest:censo": "tsx src/ingestion/cli.ts censo",
    "ingest:enem": "tsx src/ingestion/cli.ts enem",
    "ingest:ideb": "tsx src/ingestion/cli.ts ideb",
    "ingest:pdde": "tsx src/ingestion/cli.ts pdde",
    "ingest:all": "tsx src/ingestion/cli.ts all",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "iconv-lite": "^0.6.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "winston": "^3.13.1",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.4.15",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "sequelize-cli": "^6.6.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
